# ─────────────────────────────────────────────
# Astra DB Configuration
# Get these from: https://astra.datastax.com
# ─────────────────────────────────────────────
ASTRA_DB_API_ENDPOINT=https://<your-db-id>-<region>.apps.astra.datastax.com
ASTRA_DB_APPLICATION_TOKEN=AstraCS:<your-token>
ASTRA_DB_KEYSPACE=graphCollection
ASTRA_DB_COLLECTION=itsm_documents

# ─────────────────────────────────────────────
# IBM watsonx Configuration
# Get these from: https://cloud.ibm.com/catalog/services/watson-machine-learning
# ─────────────────────────────────────────────
WATSONX_API_KEY=<your-watsonx-api-key>
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=<your-project-id>

# Embedding model — produces 1024-dimensional vectors
EMBEDDING_MODEL_ID=intfloat/multilingual-e5-large

# LLM for answer generation
LLM_MODEL_ID=ibm/granite-3-8b-instruct